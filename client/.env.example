# Fastly Bot Management — advanced client-side detection (optional)
#
# A lightweight passive detection script injected into <head> above all other
# scripts on every page load. Detects headless browsers and sets the _fs_cd_cp_
# cookie, feeding WAF signals (SUSPECTED-BOT.HEADLESS, CLIENTSIDE-COOKIE-VALID).
# No DOM element, no gating, no user-visible UI — purely passive.
#
# Script URL: /_fs-ch-1T1wmsGaOgGaSxcX/assets/<filename>
# Set the filename you chose in Fastly (e.g. "script.js"). Leave blank to disable.
VITE_FASTLY_ACSD_FILE=

# Fastly Bot Management — embedded client challenge (optional)
#
# The challenge script URL is <prefix><filename>, e.g.
#   /_fs-ch-1T1wmsGaOgGaSxcX/challenge.js
# The prefix "/_fs-ch-1T1wmsGaOgGaSxcX/" is the SAME for every Fastly customer;
# only the filename is yours to choose when you enable embedded challenges.
#
# So normally you only set the filename here. Leave it blank for local
# development: the integration stays dormant (no badge, nothing gated) and the
# app/tests behave normally. Set it to activate the discrete "Verified by Fastly
# Bot Management" badge and the soft gate on login / checkout / add-to-cart.
VITE_FASTLY_CHALLENGE_FILE=

# --- Kill switch ---
#
# Set to "true" to completely disable the challenge: no challenge.js is loaded,
# no badge, nothing gated — even if a filename is set above. Build-time off.
# (Two runtime kill switches also exist, no rebuild needed:
#   • add ?fastlychallenge=off to any page URL  — per browser, persisted
#     (?fastlychallenge=on re-enables it);
#   • set window.FASTLY_CHALLENGE_DISABLED = true — global; an operator can inject
#     this at the Fastly edge to kill it for everyone at once.)
VITE_FASTLY_CHALLENGE_DISABLED=

# --- Advanced / optional ---

# Full path override. If set, it wins over the filename above. Use this only if
# you need to point at a non-standard URL.
# VITE_FASTLY_CHALLENGE_PATH=/_fs-ch-1T1wmsGaOgGaSxcX/challenge.js

# Override the universal prefix (only if Fastly ever changes it).
# VITE_FASTLY_CHALLENGE_PREFIX=/_fs-ch-1T1wmsGaOgGaSxcX/

# Set to "false" to keep critical actions gated if the challenge script can't
# load. Default ("true") fails open after a short timeout so a Fastly asset
# hiccup can't lock customers out.
VITE_FASTLY_CHALLENGE_FAILOPEN=true

# Fastly Bot Management — embedded client challenge (optional)
#
# When the app is served behind a Fastly service with embedded client challenges
# enabled, set this to the challenge script path Fastly generates for your
# service. You'll find it in the Fastly bot-management configuration; it looks
# like "/_fs-ch-<id>/challenge.js".
#
# Leave it blank (or unset) for local development: the integration stays dormant
# — no verification badge renders and no action is gated, so the app and tests
# behave normally. Set it to activate the discrete "Verified by Fastly Bot
# Management" badge and the soft gate on login / checkout / add-to-cart.
VITE_FASTLY_CHALLENGE_PATH=

# Optional. Set to "false" to keep critical actions gated if the challenge
# script can't load. Default ("true") fails open after a short timeout so a
# Fastly asset hiccup can't lock customers out.
VITE_FASTLY_CHALLENGE_FAILOPEN=true
